# Desarrollo local. Copiar manualmente a backend/.env y completar los secretos.
# Variables obligatorias para iniciar el backend: NODE_ENV, JWT_SECRET,
# FRONTEND_URL, COOKIE_SAMESITE, DB_SSL y DATABASE_URL o todas las DB_*.
# Generar cada secreto por separado, por ejemplo:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
COOKIE_SAMESITE=lax
TRUSTED_PROXY_CIDRS=
JSON_BODY_LIMIT=1mb

DB_HOST=localhost
DB_PORT=5432
DB_NAME=cap_prenatal
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
# Alternativa: dejar sin usar las DB_* de conexion y definir DATABASE_URL.
# DATABASE_URL=

JWT_SECRET=
ACCESS_TOKEN_TTL_MINUTES=10
SESSION_IDLE_TIMEOUT_MINUTES=15
SESSION_WARNING_MINUTES=13
SESSION_ABSOLUTE_HOURS=8
SESSION_ACTIVITY_UPDATE_SECONDS=60
# Retencion para el comando manual npm run sessions:cleanup.
SESSION_RETENTION_DAYS=30

# Requeridas solo al ejecutar npm run db:seed.
# El seed crea como maximo una cuenta inicial de director.
SEED_DIRECTOR_NAME=
SEED_DIRECTOR_USERNAME=
SEED_DIRECTOR_PASSWORD=
# Produccion exige ademas la confirmacion documentada en docs/ROTACION_SECRETOS.md.
# SEED_CONFIRM_PRODUCTION=

# Lia: limites por usuario autenticado (o IP como respaldo).
CHATBOT_RATE_LIMIT_WINDOW_MS=60000
CHATBOT_MESSAGE_RATE_LIMIT=30
CHATBOT_FEEDBACK_RATE_LIMIT=20

# PDF clinico: MemoryStore por usuario autenticado mientras exista una sola instancia.
PDF_RATE_LIMIT_WINDOW_MS=300000
PDF_RATE_LIMIT=20
PDF_EXCEL_ENGINE=auto
# Windows local normalmente usa Excel COM; Docker usa LibreOffice.
# LIBREOFFICE_PATH=/usr/bin/soffice

# Automatizacion n8n v1. En desarrollo permanece deshabilitada.
N8N_INTEGRATION_ENABLED=false
N8N_API_KEY_HASH_CURRENT=
N8N_API_KEY_HASH_NEXT=
N8N_ALLOWED_CIDRS=
APPOINTMENT_NOTIFICATION_START_OFFSET_DAYS=1
APPOINTMENT_NOTIFICATION_WINDOW_DAYS=1
APPOINTMENT_NOTIFICATION_TIMEZONE=America/Guatemala
AUTOMATION_RATE_LIMIT_WINDOW_MS=900000
AUTOMATION_RATE_LIMIT_MAX=6
