DB_HOST=localhost
DB_PORT=5432
DB_NAME=cap_prenatal
DB_USER=postgres
DB_PASSWORD=change_me
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
COOKIE_SAMESITE=lax
JSON_BODY_LIMIT=1mb
PDF_EXCEL_ENGINE=auto
# Windows local usually uses Excel COM automatically.
# Docker/AWS should use libreoffice.
# LIBREOFFICE_PATH=/usr/bin/soffice

# Optional alternative for hosted databases:
# DATABASE_URL=postgresql://user:password@host:5432/cap_prenatal
