# Docker Compose local solamente. Copiar manualmente a .env y completar los secretos.
# Este archivo no contiene valores utilizables para JWT, PostgreSQL ni automatizaciones.
# Generar un valor aleatorio, por ejemplo:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

POSTGRES_DB=cap_prenatal
POSTGRES_USER=cap_prenatal_app
POSTGRES_PASSWORD=
JWT_SECRET=
AUTOMATION_SECRET=

# Opcionales al iniciar Compose; obligatorias solo para npm run db:seed.
SEED_DIRECTOR_NAME=
SEED_DIRECTOR_USERNAME=
SEED_DIRECTOR_PASSWORD=
# Solo para una ejecucion deliberada del seed en produccion.
SEED_CONFIRM_PRODUCTION=

# Valores no secretos opcionales para el entorno local.
FRONTEND_URL=http://localhost:8080,http://localhost:5173
COOKIE_SAMESITE=lax
