# Configuracion dedicada para scripts/start-n8n-local.ps1.
# Copiar manualmente a n8n/.env. No copiar backend/.env ni agregar secretos
# clinicos, JWT, SMTP, hashes del backend o credenciales seed.

# Generar una vez, guardar fuera de Git y no regenerar despues de crear
# credenciales en n8n. Minimo 32 caracteres aleatorios.
N8N_ENCRYPTION_KEY=

N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_LISTEN_ADDRESS=127.0.0.1
N8N_EDITOR_BASE_URL=http://127.0.0.1:5678/
WEBHOOK_URL=http://127.0.0.1:5678/
GENERIC_TIMEZONE=America/Guatemala
TZ=America/Guatemala

N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=24
EXECUTIONS_DATA_PRUNE_MAX_COUNT=100
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false

CAP_BACKEND_AUTOMATION_URL=http://127.0.0.1:3001/api/automatizaciones/v1/proximas-citas
CAP_SYSTEM_BASE_URL=http://127.0.0.1:8080
