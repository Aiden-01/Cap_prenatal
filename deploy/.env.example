# Inventario de variables para docker-compose.production.example.yml.
# No usar este archivo como fuente de secretos en produccion. Inyectar los
# valores vacios mediante un gestor de secretos o el entorno protegido.

POSTGRES_DB=cap_prenatal
POSTGRES_USER=cap_prenatal_app
POSTGRES_PASSWORD=
JWT_SECRET=
FRONTEND_URL=https://cap-prenatal.example.invalid

N8N_INTEGRATION_ENABLED=false
N8N_API_KEY_HASH_CURRENT=
N8N_API_KEY_HASH_NEXT=
N8N_ENCRYPTION_KEY=

N8N_HOST=n8n-admin.example.invalid
N8N_EDITOR_BASE_URL=https://n8n-admin.example.invalid/
WEBHOOK_URL=https://n8n-webhook.example.invalid/
CAP_SYSTEM_BASE_URL=https://cap-prenatal.example.invalid
